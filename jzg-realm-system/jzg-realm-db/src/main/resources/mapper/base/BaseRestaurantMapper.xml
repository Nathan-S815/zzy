<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.BaseRestaurantMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.BaseRestaurant">
        <id column="id" property="id" />
        <result column="restaurant_name" property="restaurantName" />
        <result column="restaurant_level" property="restaurantLevel" />
        <result column="credit_code" property="creditCode" />
        <result column="area_code" property="areaCode" />
        <result column="lat" property="lat" />
        <result column="lng" property="lng" />
        <result column="zip_code" property="zipCode" />
        <result column="site_type" property="siteType" />
        <result column="zx_phone" property="zxPhone" />
        <result column="ts_phone" property="tsPhone" />
        <result column="room_num" property="roomNum" />
        <result column="car_park_num" property="carParkNum" />
        <result column="business_time" property="businessTime" />
        <result column="website" property="website" />
        <result column="reservation_website" property="reservationWebsite" />
        <result column="wechat_name" property="wechatName" />
        <result column="microblog_name" property="microblogName" />
        <result column="price_descript" property="priceDescript" />
        <result column="hotel_descript" property="hotelDescript" />
        <result column="favoured_policy" property="favouredPolicy" />
        <result column="line_suggest" property="lineSuggest" />
        <result column="create_time" property="createTime" />
        <result column="remark" property="remark" />
        <result column="pic_url" property="picUrl" />
        <result column="is_delete" property="isDelete" />
        <result column="user_id" property="userId" />
    </resultMap>
    <select id="selectPageListBaseRestaurant" resultMap="BaseResultMap">
        select * from base_restaurant
        <where>
            <if test="departName!=null ">
                and restaurant_name like Concat('%',#{departName},'%')
            </if>
        </where>
        order by create_time desc
    </select>
</mapper>
