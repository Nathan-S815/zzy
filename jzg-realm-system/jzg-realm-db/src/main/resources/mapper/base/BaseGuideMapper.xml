<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.BaseGuideMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.BaseGuide">
        <id column="id" property="id" />
        <result column="guide_name" property="guideName" />
        <result column="sex" property="sex" />
        <result column="id_number" property="idNumber" />
        <result column="birthday" property="birthday" />
        <result column="tel" property="tel" />
        <result column="nation" property="nation" />
        <result column="educational" property="educational" />
        <result column="major" property="major" />
        <result column="graduation_university" property="graduationUniversity" />
        <result column="sub_travel" property="subTravel" />
        <result column="guide_certificate" property="guideCertificate" />
        <result column="grade_num" property="gradeNum" />
        <result column="guide_grade" property="guideGrade" />
        <result column="language_grade" property="languageGrade" />
        <result column="seniority_certificate" property="seniorityCertificate" />
        <result column="nature_work" property="natureWork" />
        <result column="registe_organ_name" property="registeOrganName" />
        <result column="apply_time" property="applyTime" />
        <result column="approval_time" property="approvalTime" />
        <result column="create_time" property="createTime" />
        <result column="remark" property="remark" />
        <result column="pic_url" property="picUrl" />
        <result column="is_delete" property="isDelete" />
    </resultMap>
    <select id="selectPageListBaseGuide" resultMap="BaseResultMap">
        select * from base_guide
       <where>
        <if test="departName!=null ">
            and guide_name like Concat('%',#{departName},'%')
        </if>
       </where>
        order by create_time desc
    </select>
</mapper>
