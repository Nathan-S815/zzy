<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.WeatherInfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.WeatherInfo">
        <id column="id" property="id" />
        <result column="temp" property="temp" />
        <result column="weather_index" property="weatherIndex" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, temp, weather_index
    </sql>

    <select id="getTempAndIndex" resultType="java.util.Map">
        select temp, weather_index weatherIndex from weather_info
    </select>

</mapper>
