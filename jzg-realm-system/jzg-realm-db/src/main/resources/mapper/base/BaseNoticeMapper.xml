<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.BaseNoticeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.BaseNotice">
        <id column="id" property="id" />
        <result column="title" property="title" />
        <result column="source" property="source" />
        <result column="type" property="type" />
        <result column="introduction" property="introduction" />
        <result column="pic" property="pic" />
        <result column="content" property="content" />
        <result column="create_time" property="createTime" />
        <result column="is_delete" property="isDelete" />
        <result column="update_time" property="updateTime" />
        <result column="report_time" property="reportTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, title, source, type, introduction, pic, content, create_time, is_delete, update_time, report_time
    </sql>

    <select id="selectPageListBaseNotice" resultMap="BaseResultMap">
        select * from base_notice
        where is_delete = 0
        <if test="keyword!=null">
            and title like concat('%',#{keyword},'%')
        </if>
        order by report_time desc
    </select>
</mapper>
