<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.BaseTravelMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.BaseTravel">
        <id column="id" property="id" />
        <result column="travel_name" property="travelName" />
        <result column="travel_level" property="travelLevel" />
        <result column="credit_code" property="creditCode" />
        <result column="area_code" property="areaCode" />
        <result column="lat" property="lat" />
        <result column="lng" property="lng" />
        <result column="zip_code" property="zipCode" />
        <result column="site_type" property="siteType" />
        <result column="zx_phone" property="zxPhone" />
        <result column="ts_phone" property="tsPhone" />
        <result column="license_no" property="licenseNo" />
        <result column="legal_person" property="legalPerson" />
        <result column="contributor" property="contributor" />
        <result column="create_time" property="createTime" />
        <result column="remark" property="remark" />
        <result column="pic_url" property="picUrl" />
        <result column="is_delete" property="isDelete" />
        <result column="user_id" property="userId" />
    </resultMap>
    <select id="selectPageListBaseTravel" resultMap="BaseResultMap">
        select * from base_travel
        <where>
            <if test="departName!=null ">
                and travel_name like Concat('%',#{departName},'%')
            </if>
        </where>
        order by create_time desc
    </select>
</mapper>
