<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.InfoPromotionVideoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.InfoPromotionVideo">
        <id column="id" property="id" />
        <result column="create_time" property="createTime" />
        <result column="video_name" property="videoName" />
        <result column="video_address" property="videoAddress" />
        <result column="video_status" property="videoStatus" />
        <result column="create_name" property="createName" />
        <result column="descriptio" property="descriptio" />
        <result column="is_delete" property="isDelete" />
        <result column="release_place" property="releasePlace" />
        <result column="use_place" property="usePlace" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, create_time, video_name, video_address, video_status, create_name, descriptio, is_delete, release_place, use_place
    </sql>

    <select id="selectPageListInfoPromotionVideo" resultMap="BaseResultMap">
        select * from info_promotion_video
        <where>
            <if test="departName!=null ">
                and video_name like Concat('%',#{departName},'%')
            </if>
        </where>
        order by create_time desc
    </select>

</mapper>
