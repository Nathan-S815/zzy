<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.base.BaseScenicMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.base.BaseScenic">
        <id column="id" property="id" />
        <result column="scenic_name" property="scenicName" />
        <result column="scenic_level" property="scenicLevel" />
        <result column="credit_code" property="creditCode" />
        <result column="area_code" property="areaCode" />
        <result column="lat" property="lat" />
        <result column="lng" property="lng" />
        <result column="zip_code" property="zipCode" />
        <result column="site_type" property="siteType" />
        <result column="appropriate_month" property="appropriateMonth" />
        <result column="zx_phone" property="zxPhone" />
        <result column="ts_phone" property="tsPhone" />
        <result column="emergency_phone" property="emergencyPhone" />
        <result column="instant_capacity" property="instantCapacity" />
        <result column="day_capacity" property="dayCapacity" />
        <result column="car_park_num" property="carParkNum" />
        <result column="ticket_explain" property="ticketExplain" />
        <result column="open_time" property="openTime" />
        <result column="favoured_policy" property="favouredPolicy" />
        <result column="remind" property="remind" />
        <result column="website" property="website" />
        <result column="wechat_name" property="wechatName" />
        <result column="microblog_name" property="microblogName" />
        <result column="vr_address" property="vrAddress" />
        <result column="scenic_title" property="scenicTitle" />
        <result column="line_suggest" property="lineSuggest" />
        <result column="create_time" property="createTime" />
        <result column="remark" property="remark" />
        <result column="pic_url" property="picUrl" />
        <result column="is_delete" property="isDelete" />
        <result column="user_id" property="userId" />
        <result column="warning" property="warning" />
    </resultMap>
    <select id="selectPageList" resultMap="BaseResultMap">
        select * from base_scenic
        <where>
            <if test="userId!=null ">
                and user_id =#{userId}
            </if>
            <if test="departName!=null ">
                and scenic_name like Concat('%',#{departName},'%')
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectByScenicName" resultMap="BaseResultMap">
        select * from base_scenic where scenic_name = #{scenicName}
    </select>

</mapper>
