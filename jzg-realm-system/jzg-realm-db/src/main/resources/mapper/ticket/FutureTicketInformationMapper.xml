<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.ticket.FutureTicketInformationMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.ticket.FutureTicketInformation">
        <id column="id" property="id" />
        <result column="api_id" property="apiId" />
        <result column="name" property="name" />
        <result column="record_date" property="recordDate" />
        <result column="rest_number" property="restNumber" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, api_id, `name`, record_date, rest_number, create_time, update_time
    </sql>

    <insert id="batchInsert" parameterType="java.util.List">
        insert into future_ticket_information (id, api_id, `name`, record_date, rest_number, create_time, update_time
        )
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (
            #{item.id},
            #{item.apiId},
            #{item.name},
            #{item.recordDate},
            #{item.restNumber},
            #{item.createTime},
            #{item.updateTime}
            )
        </foreach>
        on duplicate key update
        rest_number = values(rest_number),
        update_time = sysdate()
    </insert>


    <select id="selectOneByInfo" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from future_ticket_information
        where api_id = #{apiId} and record_date = #{recordDate}
    </select>

</mapper>
