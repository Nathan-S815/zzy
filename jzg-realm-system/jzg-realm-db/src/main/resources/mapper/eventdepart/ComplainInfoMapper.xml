<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzy.db.dao.eventdepart.ComplainInfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zzy.db.entity.eventdepart.ComplainInfo">
        <id column="id" property="id" />
        <result column="complain_name" property="complainName" />
        <result column="complain_content" property="complainContent" />
        <result column="complain_type" property="complainType" />
        <result column="state" property="state" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="complain_result" property="complainResult" />
        <result column="complain_unit" property="complainUnit" />
        <result column="pic_url" property="picUrl" />
        <result column="voide_url" property="voideUrl" />
        <result column="handling" property="handling" />
        <result column="replenish" property="replenish" />
        <result column="complain_people" property="complainPeople" />
        <result column="phone" property="phone" />
        <result column="people_pic" property="peoplePic" />
        <result column="complain_id" property="complainId" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, complain_name, complain_content, complain_type, state, create_time, update_time,complain_result,
        pic_url,voide_url,handling,replenish,complain_people,phone,people_pic,complain_id
    </sql>

    <select id="listComplainInfo" resultType="java.util.Map">
        select
        id, complain_name complainName,complain_unit complainUnit,
        complain_type complainType,state, create_time createTime,
        complain_people complainPeople,phone,people_pic peoplePic
        from complain_info
        <where>
            <if test="state!=null">
              and  state=#{state}
            </if>
            <if test="createTime!=null">
              and  create_time like #{createTime}"%"
            </if>
            <if test="startTime!=null || endTime!=null">
              and  create_time between #{startTime} and #{endTime}
            </if>

        </where>
    </select>

    <update id="updateComplainInfoState">
        update complain_info set state=#{state} where id=#{id}
    </update>


    <update id="updateReplenish">
        update complain_info set replenish=#{replenish} where id=#{id}
    </update>

</mapper>
