<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nuwa.infrastructure.attract.database.travel.mapper.CustomerMapper">


    <insert id="savaInfo" useGeneratedKeys="true" keyProperty="customerId" >
        insert into customer(customer_id,name,idcard,reward) values
        <foreach collection="list" item="item" separator=",">
            (#{item.customerId},#{item.name},#{item.idcard} ,#{item.reward})
        </foreach>
    </insert>
</mapper>
